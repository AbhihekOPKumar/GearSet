<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Alerts the opportunity owner when the close date is moved to within 7 days. This flow demonstrates date-based alerts and field change detection - perfect for consolidation with other opportunity automation.</description>
    <environments>Default</environments>
    <interviewLabel>Opportunity Close Date Alert {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity Close Date Alert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Opportunity_Description</name>
        <label>Update Opportunity Description</label>
        <locationX>176</locationX>
        <locationY>350</locationY>
        <inputAssignments>
            <field>Description</field>
            <value>
                <stringValue>URGENT: Close date is {!$Record.CloseDate} - Owner alerted on {!$Flow.CurrentDateTime}</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Opportunity_Description</targetReference>
        </connector>
        <filterFormula>AND(
  ISCHANGED({!$Record.CloseDate}),
  {!$Record.CloseDate} &lt;= TODAY() + 7,
  {!$Record.CloseDate} &gt;= TODAY(),
  NOT(ISPICKVAL({!$Record.StageName}, &#39;Closed Won&#39;)),
  NOT(ISPICKVAL({!$Record.StageName}, &#39;Closed Lost&#39;))
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
